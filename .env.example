APP_NAME=Chat Backend
APP_ENV=local
DEBUG=true

DATABASE_URL=postgresql+asyncpg://chat_user:chat_pass@postgres:5432/chat_db
SYNC_DATABASE_URL=postgresql+psycopg://chat_user:chat_pass@postgres:5432/chat_db

REDIS_URL=redis://redis:6379/0

SECRET_KEY=replace-with-your-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256